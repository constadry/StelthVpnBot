# Bot configuration
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram user IDs with admin access
ADMIN_IDS=123456789

# 3x-ui panel
PANEL_URL=https://your-server-ip:54321/your-secret-path
PANEL_USER=admin
PANEL_PASS=your_panel_password

# API prefix (no /xui inside path — code appends /inbound/... after this):
#   /panel → .../panel/inbound/add  (newer 3x-ui)
#   /xui   → .../xui/inbound/add    (older 3x-ui)
API_PREFIX=/panel

# Port range for new inbounds (must not conflict with existing ones)
PORT_RANGE_START=30000
PORT_RANGE_END=40000

# SQLite paths (inside container — mapped to host via volume)
DB_PATH=/app/data/bot.db
DB_BACKUP_PATH=/app/data/bot.db.bak